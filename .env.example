# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# GDPR data retention (days a bank statement is kept before auto-deletion)
DATA_RETENTION_DAYS=1


# Comma-separated list of allowed hosts, e.g. api.example.com
ALLOWED_HOSTS=

# Comma-separated list of allowed CORS origins, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=

# --- Database ---

# "local" (default) uses the docker-compose "db" Postgres container.
# "supabase" uses a hosted Supabase Postgres instance instead - see README
# section "Using Supabase instead of the local Postgres container".
DB_ENGINE=local

# PostgreSQL credentials (must match between the db and web/cron services)
# Only used when DB_ENGINE=local
POSTGRES_DB=statement_ai_db
POSTGRES_USER=statement_ai_user
POSTGRES_PASSWORD=Test123!

# Supabase connection (only used when DB_ENGINE=supabase)
# Get these from: Supabase Dashboard -> Project Settings -> Database
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require
