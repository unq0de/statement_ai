# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# GDPR data retention (days a bank statement is kept before auto-deletion)
DATA_RETENTION_DAYS=365

# --- Production only (leave empty for local/DEBUG=1 development) ---

# Comma-separated list of allowed hosts, e.g. api.example.com
ALLOWED_HOSTS=

# Comma-separated list of allowed CORS origins, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=

# PostgreSQL credentials (must match between the db and web/cron services)
POSTGRES_DB=statement_ai_db
POSTGRES_USER=statement_ai_user
POSTGRES_PASSWORD=statement_ai_password
