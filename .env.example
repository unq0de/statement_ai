# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# GDPR data retention (days a bank statement is kept before auto-deletion)
DATA_RETENTION_DAYS=365

# --- Production only (leave empty for local/DEBUG=1 development) ---

# Comma-separated list of allowed hosts, e.g. api.example.com
ALLOWED_HOSTS=

# Comma-separated list of allowed CORS origins, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=

# PostgreSQL credentials (must match between the db and web/cron services)
POSTGRES_DB=statement_ai_db
POSTGRES_USER=statement_ai_user
POSTGRES_PASSWORD=statement_ai_password
# Override only if not running via docker-compose (e.g. Cloud Run, Cloud SQL, external DB)
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Database backend selection ---
# DB_BACKEND=local (default, uses POSTGRES_* above) or DB_BACKEND=supabase
DB_BACKEND=local

# Only needed if DB_BACKEND=supabase (use the Session Pooler connection from your Supabase dashboard)
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
