# Runs the GDPR data-retention cleanup daily at 03:00 (container time, UTC).
# Output is redirected to the container's stdout/stderr so it shows up in
# `docker compose logs cron`.
# Format: /etc/cron.d files require an explicit user column (unlike `crontab -e`).
0 3 * * * root cd /app && python manage.py delete_expired_data >> /proc/1/fd/1 2>> /proc/1/fd/2
